# ==========================================
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
node_modules/
.pnpm-store/
.gradle/
.eslintcache

# ==========================================
# IDE & Editor
# ==========================================
.vscode/
.idea/
.vs/
*.swp
*.swo

# ==========================================
# Virtual Environments
# ==========================================
.venv/
.venv*/
venv/
venv*/
env/
ENV/

