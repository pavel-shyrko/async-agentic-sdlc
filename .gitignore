# ==========================================
# Runtime Bytecode / Compiled Output
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.class
bin/
obj/
target/

runs/

# ==========================================
# Corporate CA — staged into the build context at build time, NEVER committed
# (the public root cert is provisioned from the host by build_sandbox_images.sh).
# ==========================================
docker/certs/*.crt
docker/certs/*.pem

# ==========================================
# Testing & Coverage
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json

