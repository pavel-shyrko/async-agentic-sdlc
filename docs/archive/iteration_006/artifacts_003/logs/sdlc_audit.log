import math

from .base import Shape
from .validation import _validate_positive_number


class Circle(Shape):
    def __init__(self, radius: float):
        _validate_positive_number(radius, "radius")
        self.radius = radius

    def area(self) -> float:
        return math.pi * self.radius * self.radius


class Rectangle(Shape):
    def __init__(self, width: float, height: float):
        _validate_positive_number(width, "width")
        _validate_positive_number(height, "height")
        self.width = width
        self.height = height

    def area(self) -> float:
        return float(self.width * self.height)


=== FILE: src/geometry/validation.py ===
from typing import Union


def _validate_positive_number(value: Union[int, float], name: str) -> None:
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        raise TypeError(f"{name} must be an int or float, got {type(value).__name__}")
    if value <= 0:
        raise ValueError(f"{name} must be strictly greater than zero, got {value}")


=== FILE: src/geometry/volume.py ===
from .shapes import Circle, Rectangle
from .validation import _validate_positive_number


class Cylinder:
    def __init__(self, base_shape: Circle, height: float):
        if not isinstance(base_shape, Circle):
            raise TypeError(
                f"base_shape must be a Circle, got {type(base_shape).__name__}"
            )
        _validate_positive_number(height, "height")
        self.base_shape = base_shape
        self.height = height

    def volume(self) -> float:
        return self.base_shape.area() * self.height


class Cuboid:
    def __init__(self, base_shape: Rectangle, height: float):
        if not isinstance(base_shape, Rectangle):
            raise TypeError(
                f"base_shape must be a Rectangle, got {type(base_shape).__name__}"
            )
        _validate_positive_number(height, "height")
        self.base_shape = base_shape
        self.height = height

    def volume(self) -> float:
        return self.base_shape.area() * self.height

